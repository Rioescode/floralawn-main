# SECURITY WARNING: Never commit .env files to version control
# Copy this file to .env.local and fill in your actual values

# -----------------------------------------------------------------------------
# NextAuth: https://shipfa.st/docs/tutorials/user-auth
# -----------------------------------------------------------------------------
NEXTAUTH_URL=https://yourdomain.com
NEXTAUTH_SECRET=your_nextauth_secret_key_min_32_chars

# -----------------------------------------------------------------------------
# Google OAuth: https://shipfa.st/docs/features/google-oauth
# -----------------------------------------------------------------------------
GOOGLE_ID=
GOOGLE_SECRET=

# -----------------------------------------------------------------------------
# Resend: https://shipfa.st/docs/features/emails
# -----------------------------------------------------------------------------
RESEND_API_KEY=your_resend_api_key

# -----------------------------------------------------------------------------
# Database URI: https://shipfa.st/docs/features/database
# -----------------------------------------------------------------------------
MONGODB_URI=your_mongodb_connection_string

# -----------------------------------------------------------------------------
# Stripe: https://shipfa.st/docs/features/payments
# -----------------------------------------------------------------------------
STRIPE_PUBLIC_KEY=
STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=

# EmailJS Credentials
NEXT_PUBLIC_EMAILJS_SERVICE_ID=your_emailjs_service_id
NEXT_PUBLIC_EMAILJS_TEMPLATE_ID=your_emailjs_template_id
NEXT_PUBLIC_EMAILJS_PUBLIC_KEY=your_emailjs_public_key

# Supabase Configuration
NEXT_PUBLIC_SUPABASE_URL=your_supabase_project_url
NEXT_PUBLIC_SUPABASE_ANON_KEY=your_supabase_anon_key
SUPABASE_SERVICE_ROLE_KEY=your_supabase_service_role_key

# App Configuration
NEXT_PUBLIC_APP_NAME="Flora Lawn & Landscaping Inc"
SITE_URL=https://yourdomain.com

# Telegram Notifications (Optional) - Server-side only
TELEGRAM_TOKEN=your_telegram_bot_token
TELEGRAM_CHAT_ID=your_telegram_chat_id

# Google Maps API - Server-side only (for geocoding and route optimization)
GOOGLE_MAPS_API_KEY=your_google_maps_api_key

# Google Maps API - Client-side (for autocomplete suggestions)
NEXT_PUBLIC_GOOGLE_MAPS_API_KEY=your_google_maps_api_key

# Anthropic API (Claude AI)
ANTHROPIC_API_KEY=your_anthropic_api_key

# Security Notes:
# 1. Use strong, unique API keys
# 2. Rotate keys regularly
# 3. Use different keys for development/production
# 4. Monitor API usage for unusual activity
# 5. Set up proper CORS policies
# 6. Enable rate limiting in production